<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SatelliteDemo.MainWindow"
        Title="Tri-role Demo — drag to detach / snap / dock"
        Width="780" Height="480">

    <DockPanel>
        <!-- Status -->
        <Border DockPanel.Dock="Top" Padding="12" Background="#202020">
            <StackPanel>
                <TextBlock Text="Drag the grip out of the dock slot. Drop near a main-window edge to snap; drop on the dock slot to re-dock; drop anywhere else to float."
                           Foreground="#C0C0C0" TextWrapping="Wrap" />
                <TextBlock x:Name="StatusText" Foreground="#80C080" Margin="0,6,0,0" Text="Mode: Docked" />
            </StackPanel>
        </Border>

        <!-- Dock slot (always visible — doubles as drop target) -->
        <Border x:Name="DockSlot" DockPanel.Dock="Right" Width="260"
                Background="#30556B2F" BorderBrush="#80556B2F" BorderThickness="2"
                Padding="0">
            <DockPanel x:Name="DockSlotLayout">
                <!-- Drag grip (shown when content is docked) -->
                <Border x:Name="DragGrip" DockPanel.Dock="Top"
                        Background="#406B8E23" Padding="8"
                        Cursor="SizeAll">
                    <TextBlock Text="≡  Tools  (drag to detach)" Foreground="White" />
                </Border>
                <!-- Drop placeholder (shown when content is popped out) -->
                <TextBlock x:Name="DropPlaceholder" IsVisible="False"
                           Text="Drop window here to dock"
                           Foreground="#A0A0A0" FontStyle="Italic"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" />
                <!-- Live panel content goes here when docked -->
                <ContentControl x:Name="DockContentHost" />
            </DockPanel>
        </Border>

        <Border Background="#101010">
            <TextBlock Text="Main window content"
                       Foreground="#808080" FontSize="20"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </DockPanel>
</Window>
